# Multiply by repeated addition
# filename: mult_loop_test
# isa: 3bit_v1
# description: Computes RAM[0] * RAM[1] by adding RAM[0] to accumulator RAM[2]
#   RAM[1] times. Verifies loop labels, ADD, SUB, CMP, and JGT.
#   Expected: multiplicand=3, multiplier=2 -> result=6 in RAM[2]

# ── Initialization ────────────────────────────────────────────────────────────
movl 3 0 0    # RAM[0] = 3  (multiplicand)
movl 2 0 1    # RAM[1] = 2  (multiplier / loop counter)
movl 0 0 2    # RAM[2] = 0  (accumulator, will hold product)
movl 1 0 3    # RAM[3] = 1  (constant 1 for decrement)
movl 0 0 4    # RAM[4] = 0  (constant 0 for loop termination compare)

# ── Multiply loop ─────────────────────────────────────────────────────────────
def loop
add 2 0 2     # RAM[2] += RAM[0]  (accumulate)
sub 1 3 1     # RAM[1] -= 1       (decrement counter)
cmp 1 0 4     # compare RAM[1] vs RAM[0:4]  (is counter > 0?)
jgt loop      # if counter > 0, keep looping

halt
