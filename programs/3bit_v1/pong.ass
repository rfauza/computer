def ball_go_up
movl 7 0 6 #if y pos == 7, y vel == 7 (-1)
cmp 0 0 0
jeq inc_y

def ball_go_down
movl 1 0 6 #if y pos == 0, y vel == 1
cmp 0 0 0
jeq inc_y

