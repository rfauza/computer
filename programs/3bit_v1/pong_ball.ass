# pong_bar 3-bit v1
# filename: pong_ball.ass
# isa: 3bit_v1
# ball that bounces around screen
# 3-bit v1 ISA:
# 000 HALT   - Stop execution
# 001 MOVL   - Move literal: litA -> [BC]
# 010 ADD    - Add: [A] + [B] -> [C]
# 011 SUB    - Subtract: [A] - [B] -> [C]
# 100 CMP    - Compare: flags <- [0:A] vs [B:C]
# 101 JEQ    - Jump if equal: if flag then goto ABC
# 110 JGT    - Jump if greater: if flag then goto ABC
# 111 NOP    - No operation

# setup
# movl 0 0 0 # &0 = 0 zero for clearing
movl 1 0 1 # literal 1 for drawing bar and inc/decrementing
movl 2 0 2 # literal 2 for drawing second pixel, temp 4 for drawing right pixel
# movl 0 0 3 # &3 ball position x
# movl 0 0 4 # &4 ball position y
# movl 1 0 5 # &5 ball velocity x
# movl 1 0 6 # &6 ball velocity y
# &7 bar position
movl 1 1 1 # use page 1 for comparing
movl 2 1 2
movl 3 1 3
movl 4 1 4
movl 5 1 5
movl 6 1 6
movl 7 1 7

