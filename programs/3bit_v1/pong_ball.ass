###########################
### UPDATE BALL POS/VEL ###
###########################

def move_ball
movl 2 0 2 # restore 2 to &2 in case there was a 4
# check x boundaries
#if x pos == 7, x vel == 7 (-1)
def check_right
cmp 3 1 7 # if x == 7
jeq ball_go_left
def check_left
cmp 3 1 0 # if x == 0
jeq ball_go_right
def inc_x
add 3 5 3 # x pos += x vel
# fallthrough

# check y boundaries
def check_bottom
cmp 4 1 7 # if y == 7
jeq ball_go_up
def check_top
cmp 4 1 0 # if y == 
jeq ball_go_down
def inc_y
add 4 6 4 # y pos += y vel
cmp 0 0 0
jeq draw_ball

def ball_go_left
movl 7 0 5 #if x pos == 7, x vel == 7 (-1)
cmp 0 0 0
jeq inc_x

def ball_go_right
movl 1 0 5 #if x pos == 0, x vel == 1
cmp 0 0 0
jeq inc_x

def ball_go_up
movl 7 0 6 #if y pos == 7, y vel == 7 (-1)
cmp 0 0 0
jeq inc_y

def ball_go_down
movl 1 0 6 #if y pos == 0, y vel == 1
cmp 0 0 0
jeq inc_y

