# ms_paint 3-bit v1
# filename: cursor.ass
# isa: 3bit_v1
# light up one LED of the 8x8 display at a time, going down the line
# 3-bit v1 ISA:
# 000 HALT   - Stop execution
# 001 MOVL   - Move literal: litA -> [BC]
# 010 ADD    - Add: [A] + [B] -> [C]
# 011 SUB    - Subtract: [A] - [B] -> [C]
# 100 CMP    - Compare: flags <- [0:A] vs [B:C]
# 101 JEQ    - Jump if equal: if flag then goto ABC
# 110 JGT    - Jump if greater: if flag then goto ABC
# 111 NOP    - No operation

# setup
# &0 is zero ref
movl 1 0 1 # &1 is 1 ref
movl 2 0 2 # &2 is 2 ref
movl 4 0 4 # &4 is 4 ref
# cursor x position &6
# cursor y position &7

movl 1 1 1 # use page 1 for comparing
movl 2 1 2
movl 3 1 3
movl 4 1 4
movl 5 1 5
movl 6 1 6
movl 7 1 7

