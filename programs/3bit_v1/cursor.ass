########################
### INPUT PROCESSING ###
########################

def wait_input
cmp 1 4 1 # compare 1 and 4.1: detect w input
jeq move_up
cmp 1 4 2 # compare 1 and 4.2: detect a input
jeq move_left
cmp 1 4 3 # compare 1 and 4.3: detect s input
jeq move_down
cmp 1 4 4 # compare 1 and 4.4: detect d input
jeq move_right
# cmp 1 4 0 # compare 1 and 4.0: detect space input
# jeq toggle
cmp 0 0 0 # if no inputs, repeat loop
jeq wait_input # loop and wait for input

def move_up
movout 0 4 1 # clear a input
cmp 7 1 0 # check for boundaries
jeq place_cursor # if at boundary, ignore input
sub 7 1 7 # deccrement y pos
cmp 0 0 0
jeq place_cursor

def move_left
movout 0 4 2 # clear a input
cmp 6 1 0 # check for boundaries
jeq place_cursor # if at boundary, ignore input
sub 6 1 6 # decrement x pos
cmp 0 0 0
jeq place_cursor

def move_down
movout 0 4 3 # clear a input
cmp 7 1 7 # check for boundaries
jeq place_cursor # if at boundary, ignore input
add 7 1 7 # increment y pos
cmp 0 0 0
jeq place_cursor

def move_right
movout 0 4 4 # clear d input
cmp 6 1 7 # check for boundaries
jeq place_cursor # if at boundary, ignore input
add 6 1 6 # increment x pos
cmp 0 0 0
jeq place_cursor

